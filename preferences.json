[
  {
    "property": "zen-browser-utilities.contextMenu.enabled",
    "label": "Show this mod's custom actions in the tab right-click context menu",
    "type": "checkbox",
    "defaultValue": true
  },
  {
    "property": "zen-browser-utilities.close.batchSize",
    "label": "Bulk close batch size (recommended 10-30)",
    "type": "string",
    "defaultValue": "20",
    "placeholder": "20"
  },
  {
    "property": "zen-browser-utilities.close.batchDelayMs",
    "label": "Delay between close batches in milliseconds",
    "type": "string",
    "defaultValue": "120",
    "placeholder": "120"
  },
  {
    "property": "zen-browser-utilities.stale.autoCloseEnabled",
    "label": "Automatically close stale unpinned tabs",
    "type": "checkbox",
    "defaultValue": false
  },
  {
    "property": "zen-browser-utilities.stale.maxAgeMinutes",
    "label": "Minutes of inactivity before a tab becomes stale",
    "type": "string",
    "defaultValue": "10080",
    "placeholder": "10080"
  },
  {
    "property": "zen-browser-utilities.stale.checkIntervalMinutes",
    "label": "Minutes between automatic stale-tab cleanup checks",
    "type": "string",
    "defaultValue": "15",
    "placeholder": "15"
  },
  {
    "property": "zen-browser-utilities.stale.ignoreAudible",
    "label": "Do not auto-close tabs that are currently producing audio",
    "type": "checkbox",
    "defaultValue": true
  }
]
